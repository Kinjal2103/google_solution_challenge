# Backend server port
PORT=3000

# Supabase project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase service role key (secret, backend only)
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Optional: demo seed credentials (used by `npm run seed`)
SEED_COORDINATOR_EMAIL=coordinator@needbridge.org
SEED_COORDINATOR_PASSWORD=NeedBridge123!
SEED_VOLUNTEER_PASSWORD=NeedBridgeVolunteer123!
SEED_ORGANIZATION_NAME=NeedBridge Relief Network
SEED_ORGANIZATION_EMAIL=coordinator@needbridge.org

# Optional: external matching service base URL (if you want backend to call your algorithm service)
# Example: https://your-matching-service.onrender.com
MATCHING_URL=
