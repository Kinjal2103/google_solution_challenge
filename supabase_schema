-- Extensions (Supabase enables these by default, but be explicit)
CREATE EXTENSION IF NOT EXISTS "pgcrypto";     -- gen_random_uuid()
CREATE EXTENSION IF NOT EXISTS "btree_gist";   -- GiST on composite indexes

-- ============================================================
-- ENUMS
-- Enums over text columns for all finite state machines.
-- Adding a value: ALTER TYPE ... ADD VALUE (no downtime).
-- Removing a value: requires migration — intentionally hard.
-- ============================================================

CREATE TYPE org_type AS ENUM (
  'ngo', 'community_group', 'government', 'faith_based', 'other'
);

CREATE TYPE need_status AS ENUM (
  'open',        -- newly reported, awaiting assignment
  'assigned',    -- at least one volunteer assigned
  'in_progress', -- volunteer confirmed on-site
  'fulfilled',   -- outcome recorded as met
  'cancelled',   -- withdrawn by org or coordinator
  'merged'       -- deduplicated into another need
);

CREATE TYPE need_category AS ENUM (
  'food', 'water', 'shelter', 'medical', 'education',
  'sanitation', 'psychosocial', 'livelihood', 'other'
);

CREATE TYPE assignment_status AS ENUM (
  'pending',    -- assigned, not yet accepted by volunteer
  'accepted',   -- volunteer confirmed
  'en_route',   -- volunteer checked in as travelling
  'on_site',    -- volunteer checked in at location
  'completed',  -- volunteer marked done
  'cancelled',  -- dropped before completion
  'no_show'     -- volunteer did not appear
);

-- ============================================================
-- TABLE: organizations
-- ============================================================

CREATE TABLE organizations (
  id               UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  name             TEXT NOT NULL,
  type             org_type NOT NULL DEFAULT 'ngo',
  contact_email    TEXT NOT NULL,
  contact_phone    TEXT,
  -- location stored as (longitude, latitude) matching GeoJSON convention
  location         POINT,
  verified         BOOLEAN NOT NULL DEFAULT FALSE,
  -- soft-delete: never hard-delete an org that owns historical data
  deleted_at       TIMESTAMP WITH TIME ZONE,
  created_at       TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT NOW(),
  updated_at       TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT NOW(),

  CONSTRAINT orgs_email_format CHECK (contact_email ~* '^[^@\s]+@[^@\s]+\.[^@\s]+$'),
  CONSTRAINT orgs_name_nonempty CHECK (char_length(TRIM(name)) > 0)
);

CREATE UNIQUE INDEX orgs_email_unique ON organizations (contact_email)
  WHERE deleted_at IS NULL;

-- ============================================================
-- TABLE: volunteers
-- ============================================================

CREATE TABLE volunteers (
  id                UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  organization_id   UUID REFERENCES organizations(id) ON DELETE RESTRICT,
  full_name         TEXT NOT NULL,
  email             TEXT NOT NULL,
  phone             TEXT,
 zone VARCHAR(100),
  -- skills: ['medical', 'driving', 'translation'] — matched against need requirements
  skills            TEXT[] NOT NULL DEFAULT '{}',
  -- availability: ['mon_morning', 'wed_evening'] — structured tokens, not free text
  availability      TEXT[] NOT NULL DEFAULT '{}',
  -- max distance volunteer will travel (km)
  radius_km         NUMERIC(6,2) NOT NULL DEFAULT 10.0,
  active            BOOLEAN NOT NULL DEFAULT TRUE,
  -- 0–100 score updated by outcome feedback loop (Week 2)
  reliability_score INTEGER NOT NULL DEFAULT 50,
  deleted_at        TIMESTAMP WITH TIME ZONE,
  created_at        TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT NOW(),
  updated_at        TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT NOW(),

  CONSTRAINT vol_email_format   CHECK (email ~* '^[^@\s]+@[^@\s]+\.[^@\s]+$'),
  CONSTRAINT vol_radius_positive CHECK (radius_km > 0),
  CONSTRAINT vol_reliability_range CHECK (reliability_score BETWEEN 0 AND 100),
  CONSTRAINT vol_name_nonempty  CHECK (char_length(TRIM(full_name)) > 0)
);

CREATE UNIQUE INDEX vols_email_unique ON volunteers (email)
  WHERE deleted_at IS NULL;

-- GIN index: enables `skills && ARRAY['medical','driving']` queries
CREATE INDEX vols_skills_gin   ON volunteers USING GIN (skills);
CREATE INDEX vols_avail_gin    ON volunteers USING GIN (availability);
CREATE INDEX vols_active       ON volunteers (active) WHERE active = TRUE;
CREATE INDEX vols_org          ON volunteers (organization_id);

-- ============================================================
-- TABLE: needs
-- ============================================================

CREATE TABLE needs (
  id                     UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  organization_id        UUID NOT NULL REFERENCES organizations(id) ON DELETE RESTRICT,

  -- Self-referential: when deduplicated, points to surviving need
  merged_into_id         UUID REFERENCES needs(id) ON DELETE RESTRICT,

  title                  TEXT NOT NULL,
  description            TEXT,
  category               need_category NOT NULL,
  status                 need_status NOT NULL DEFAULT 'open',
 zone VARCHAR(100),
  -- Urgency inputs (raw)
  severity               INTEGER NOT NULL DEFAULT 3, -- 1 (low) to 5 (critical)
  vulnerability_index    INTEGER NOT NULL DEFAULT 3, -- 1–5, set by coordinator
  people_affected        INTEGER NOT NULL DEFAULT 1,
  hours_until_deadline   INTEGER,                    -- NULL = no hard deadline

  urgency_score INTEGER NOT NULL DEFAULT 0,

  volunteer_count_needed INTEGER NOT NULL DEFAULT 1,
  -- Skills the matching engine should filter on
  required_skills        TEXT[] NOT NULL DEFAULT '{}',

  needed_by              TIMESTAMP WITH TIME ZONE,

  -- Flexible per-category fields: {"litres": 500, "water_type": "potable"}
  metadata               JSONB NOT NULL DEFAULT '{}',

  -- Dedup lock: prevents concurrent merges of the same need
  dedup_locked_at        TIMESTAMP WITH TIME ZONE,

  created_at             TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT NOW(),
  updated_at             TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT NOW(),

  -- A merged need must point somewhere
  CONSTRAINT needs_merged_has_target
    CHECK (status != 'merged' OR merged_into_id IS NOT NULL),
  -- A non-merged need must not point anywhere
  CONSTRAINT needs_nonmerged_no_target
    CHECK (status = 'merged' OR merged_into_id IS NULL),
  CONSTRAINT needs_severity_range     CHECK (severity BETWEEN 1 AND 5),
  CONSTRAINT needs_vuln_range         CHECK (vulnerability_index BETWEEN 1 AND 5),
  CONSTRAINT needs_people_positive    CHECK (people_affected > 0),
  CONSTRAINT needs_vol_count_positive CHECK (volunteer_count_needed > 0),
  CONSTRAINT needs_title_nonempty     CHECK (char_length(TRIM(title)) > 0),
  -- needed_by must be in the future at insert time
  CONSTRAINT needs_deadline_future
    CHECK (needed_by IS NULL OR needed_by > created_at)
);

-- GiST index: enables fast geospatial proximity queries for dedup + map

CREATE INDEX needs_status         ON needs (status) WHERE status = 'open';
CREATE INDEX needs_category       ON needs (category);
CREATE INDEX needs_urgency        ON needs (urgency_score DESC) WHERE status = 'open';
CREATE INDEX needs_org            ON needs (organization_id);
CREATE INDEX needs_skills_gin     ON needs USING GIN (required_skills);
CREATE INDEX needs_metadata_gin   ON needs USING GIN (metadata);
-- Partial index: only non-merged needs are candidates for dedup

-- ============================================================
-- TABLE: assignments
-- ============================================================

CREATE TABLE assignments (
  id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  need_id         UUID NOT NULL REFERENCES needs(id) ON DELETE RESTRICT,
  volunteer_id    UUID NOT NULL REFERENCES volunteers(id) ON DELETE RESTRICT,
  status          assignment_status NOT NULL DEFAULT 'pending',

  -- Who triggered this assignment: 'system' | 'coordinator:<uuid>' | 'volunteer'
  assigned_by     TEXT NOT NULL DEFAULT 'system',

  assigned_at     TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT NOW(),
  accepted_at     TIMESTAMP WITH TIME ZONE,
  completed_at    TIMESTAMP WITH TIME ZONE,
  notes           TEXT,

  CONSTRAINT asgn_accepted_after_assigned
    CHECK (accepted_at IS NULL OR accepted_at >= assigned_at),
  CONSTRAINT asgn_completed_after_accepted
    CHECK (completed_at IS NULL OR accepted_at IS NOT NULL),
  CONSTRAINT asgn_completed_after_assigned
    CHECK (completed_at IS NULL OR completed_at >= assigned_at)
);

-- Prevent the same volunteer being double-assigned to the same need
-- (allow cancelled/no_show to be reassigned)
CREATE UNIQUE INDEX asgn_no_duplicate
  ON assignments (need_id, volunteer_id)
  WHERE status NOT IN ('cancelled', 'no_show');

CREATE INDEX asgn_need       ON assignments (need_id);
CREATE INDEX asgn_volunteer  ON assignments (volunteer_id);
CREATE INDEX asgn_status     ON assignments (status);

-- ============================================================
-- TABLE: outcomes
-- ============================================================

CREATE TABLE outcomes (
  id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  assignment_id   UUID NOT NULL UNIQUE REFERENCES assignments(id) ON DELETE RESTRICT,

  need_met        BOOLEAN NOT NULL,
  -- 1–5 coordinator/beneficiary rating of the volunteer
  volunteer_rating INTEGER,
  feedback        TEXT,
  -- Flexible impact: {"beneficiaries_served": 12, "kg_food_delivered": 40}
  impact_data     JSONB NOT NULL DEFAULT '{}',

  recorded_at     TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT NOW(),
 updated_at TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT NOW(),
  -- FK to volunteers or a future users table — stored as UUID, validated app-side
  recorded_by     UUID NOT NULL,

  CONSTRAINT outcomes_rating_range
    CHECK (volunteer_rating IS NULL OR volunteer_rating BETWEEN 1 AND 5)
);

CREATE INDEX outcomes_assignment ON outcomes (assignment_id);
CREATE INDEX outcomes_need_met   ON outcomes (need_met);
CREATE INDEX outcomes_impact_gin ON outcomes USING GIN (impact_data);

-- ============================================================
-- TABLE: need_history  (audit trail — written by trigger)
-- ============================================================

CREATE TABLE need_history (
  id            UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  need_id       UUID NOT NULL REFERENCES needs(id) ON DELETE CASCADE,
  old_data      JSONB NOT NULL,
  new_data      JSONB NOT NULL,
  -- 'system' | 'api:<endpoint>' | 'user:<uuid>'
  changed_by    TEXT NOT NULL DEFAULT 'system',
  change_reason TEXT,
  changed_at    TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT NOW()
);

CREATE INDEX need_hist_need   ON need_history (need_id);
CREATE INDEX need_hist_time   ON need_history (changed_at DESC);

-- ============================================================
-- TABLE: assignment_history  (audit trail — written by trigger)
-- ============================================================

CREATE TABLE assignment_history (
  id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  assignment_id   UUID NOT NULL REFERENCES assignments(id) ON DELETE CASCADE,
  old_status      assignment_status NOT NULL,
  new_status      assignment_status NOT NULL,
  changed_by      TEXT NOT NULL DEFAULT 'system',
  changed_at      TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT NOW()
);

CREATE INDEX asgn_hist_asgn  ON assignment_history (assignment_id);
CREATE INDEX asgn_hist_time  ON assignment_history (changed_at DESC);

-- ============================================================
-- TRIGGERS
-- ============================================================

-- 1. Auto-update updated_at on any row change
CREATE OR REPLACE FUNCTION set_updated_at()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
BEGIN
  NEW.updated_at = NOW();
  RETURN NEW;
END;
$$;

CREATE TRIGGER trg_organizations_updated_at
  BEFORE UPDATE ON organizations
  FOR EACH ROW EXECUTE FUNCTION set_updated_at();

CREATE TRIGGER trg_volunteers_updated_at
  BEFORE UPDATE ON volunteers
  FOR EACH ROW EXECUTE FUNCTION set_updated_at();

CREATE TRIGGER trg_needs_updated_at
  BEFORE UPDATE ON needs
  FOR EACH ROW EXECUTE FUNCTION set_updated_at();

-- 2. Audit trigger for needs
CREATE OR REPLACE FUNCTION audit_need_change()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
BEGIN
  -- Skip if nothing meaningful changed (e.g. only updated_at ticked)
  IF OLD.status       IS DISTINCT FROM NEW.status       OR
     OLD.urgency_score IS DISTINCT FROM NEW.urgency_score OR
     OLD.severity     IS DISTINCT FROM NEW.severity     OR
     OLD.description  IS DISTINCT FROM NEW.description  OR
     OLD.merged_into_id IS DISTINCT FROM NEW.merged_into_id
  THEN
    INSERT INTO need_history (need_id, old_data, new_data, changed_by)
    VALUES (
      NEW.id,
      to_jsonb(OLD),
      to_jsonb(NEW),
      COALESCE(current_setting('app.current_user', TRUE), 'system')
    );
  END IF;
  RETURN NEW;
END;
$$;

CREATE TRIGGER trg_needs_audit
  AFTER UPDATE ON needs
  FOR EACH ROW EXECUTE FUNCTION audit_need_change();

-- Also capture inserts as history (full lineage from creation)
CREATE OR REPLACE FUNCTION audit_need_insert()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
BEGIN
  INSERT INTO need_history (need_id, old_data, new_data, changed_by, change_reason)
  VALUES (
    NEW.id,
    '{}'::jsonb,
    to_jsonb(NEW),
    COALESCE(current_setting('app.current_user', TRUE), 'system'),
    'created'
  );
  RETURN NEW;
END;
$$;

CREATE TRIGGER trg_needs_audit_insert
  AFTER INSERT ON needs
  FOR EACH ROW EXECUTE FUNCTION audit_need_insert();

-- 3. Audit trigger for assignments
CREATE OR REPLACE FUNCTION audit_assignment_status()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
BEGIN
  IF OLD.status IS DISTINCT FROM NEW.status THEN
    INSERT INTO assignment_history (assignment_id, old_status, new_status, changed_by)
    VALUES (
      NEW.id,
      OLD.status,
      NEW.status,
      COALESCE(current_setting('app.current_user', TRUE), 'system')
    );
  END IF;
  RETURN NEW;
END;
$$;

CREATE TRIGGER trg_assignments_audit
  AFTER UPDATE ON assignments
  FOR EACH ROW EXECUTE FUNCTION audit_assignment_status();

-- 4. Guard: prevent assigning a volunteer to a merged/cancelled need
CREATE OR REPLACE FUNCTION guard_assignment_need_status()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
DECLARE
  v_need_status need_status;
BEGIN
  SELECT status INTO v_need_status FROM needs WHERE id = NEW.need_id;
  IF v_need_status IN ('cancelled', 'merged', 'fulfilled') THEN
    RAISE EXCEPTION
      'Cannot assign to a need with status: %', v_need_status
      USING ERRCODE = 'P0001';
  END IF;
  RETURN NEW;
END;
$$;

CREATE TRIGGER trg_guard_assignment
  BEFORE INSERT ON assignments
  FOR EACH ROW EXECUTE FUNCTION guard_assignment_need_status();

-- 5. Guard: prevent recording outcome for a non-completed assignment
CREATE OR REPLACE FUNCTION guard_outcome_assignment_status()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
DECLARE
  v_status assignment_status;
BEGIN
  SELECT status INTO v_status FROM assignments WHERE id = NEW.assignment_id;
  IF v_status != 'completed' THEN
    RAISE EXCEPTION
      'Outcome can only be recorded for completed assignments, got: %', v_status
      USING ERRCODE = 'P0001';
  END IF;
  RETURN NEW;
END;
$$;

CREATE TRIGGER trg_guard_outcome
  BEFORE INSERT ON outcomes
  FOR EACH ROW EXECUTE FUNCTION guard_outcome_assignment_status();

-- 6. Auto-update need status to 'fulfilled' when outcome is recorded as need_met=true
CREATE OR REPLACE FUNCTION sync_need_on_outcome()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
BEGIN
  IF NEW.need_met = TRUE THEN
    UPDATE needs
    SET status = 'fulfilled'
    WHERE id = (
      SELECT need_id FROM assignments WHERE id = NEW.assignment_id
    )
    AND status != 'fulfilled'; -- idempotent
  END IF;
  RETURN NEW;
END;
$$;

CREATE TRIGGER trg_sync_need_fulfilled
  AFTER INSERT ON outcomes
  FOR EACH ROW EXECUTE FUNCTION sync_need_on_outcome();

